LDAP_ENABLED=true
LDAP_SERVER=ldap://127.0.0.1:389
LDAP_BASE_DN=dc=example,dc=local
LDAP_BIND_DN=cn=admin,dc=example,dc=local
LDAP_BIND_PASSWORD=admin
LDAP_USER_SEARCH_FILTER=(uid={username})

LDAP_USE_SSL=false
LDAP_STARTTLS=false
LDAP_TLS_VALIDATE=CERT_NONE
LDAP_CA_CERT_FILE=
LDAP_CONNECT_TIMEOUT=5
LDAP_RECEIVE_TIMEOUT=5

LDAP_ATTR_EMAIL=mail
LDAP_ATTR_DISPLAY_NAME=displayName
LDAP_ATTR_GUID=entryUUID
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=local
LDAP_GROUP_SEARCH_FILTER=(member={user_dn})

LDAP_DEFAULT_ROLE=user
LDAP_ADMIN_GROUP=cn=MonitorAdmins,ou=groups,dc=example,dc=local
